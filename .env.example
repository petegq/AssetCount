# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token (xoxb-...)  — from your Slack app's "OAuth & Permissions" page
SLACK_BOT_TOKEN=xoxb-your-token-here

# Signing secret — from "Basic Information" > "App Credentials"
SLACK_SIGNING_SECRET=your-signing-secret-here

# App-level token (xapp-...) — only required when SOCKET_MODE=true
# Create one under "Basic Information" > "App-Level Tokens" with scope: connections:write
SLACK_APP_TOKEN=xapp-your-app-token-here

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development

# HTTP port (only used when SOCKET_MODE=false)
PORT=3000

# true = Socket Mode (local dev, no public URL needed)
# false = HTTP mode (production with a public URL)
SOCKET_MODE=true

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default): file:./dev.db
# PostgreSQL (production): postgresql://user:pass@host:5432/dbname
DATABASE_URL=file:./dev.db

# ── Thresholds & channels ─────────────────────────────────────────────────────
# Variance fraction that triggers a discrepancy alert (0.05 = 5%)
DISCREPANCY_THRESHOLD=0.05

# Channel where discrepancy alerts are posted
AUDIT_CHANNEL=#warehouse-audit

# Channel for the daily inventory summary
DAILY_SUMMARY_CHANNEL=#warehouse-daily

# Cron expression for the daily summary (default: 06:00 every day)
DAILY_SUMMARY_CRON=0 6 * * *

# ── Spreadsheet output ────────────────────────────────────────────────────────
# Comma-separated list of asset names (or IDs) in the exact order you want
# them output by /sheet-output. Paste the result into a single spreadsheet column.
# Example: SPREADSHEET_OUTPUT_ORDER=DT Emergency Buffer,Duplicate DTs,Total Operational DTs
SPREADSHEET_OUTPUT_ORDER=

# Which unit to use for the output values: "uom" (as counted) or "uoo" (reported unit)
SPREADSHEET_OUTPUT_UNIT=uoo

# ── Logging ───────────────────────────────────────────────────────────────────
# fatal | error | warn | info | debug | trace
LOG_LEVEL=info
